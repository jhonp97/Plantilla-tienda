# ==========================================
# ⚙️ CONFIGURACIÓN DEL SERVIDOR
# ==========================================
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ==========================================
# 🗄️ BASE DE DATOS (PostgreSQL local en Docker)
# ==========================================
# No necesita API Key externa. Esta es la URL estándar en el docker-compose
DATABASE_URL="postgresql://admin:admin123@localhost:5432/tienda_db?schema=public"

# ==========================================
# 🛡️ AUTENTICACIÓN Y SEGURIDAD
# ==========================================
# Inventa una cadena de texto larga y aleatoria para firmar los tokens en local
JWT_SECRET="super_secreto_para_desarrollo_2026_xyz"
JWT_EXPIRES_IN="7d"

# Si usas OAuth (Google), necesitarás crear credenciales en Google Cloud Console
GOOGLE_CLIENT_ID="tu_google_client_id_aqui"
GOOGLE_CLIENT_SECRET="tu_google_client_secret_aqui"

# ==========================================
# 💳 PAGOS (Stripe - Modo Prueba)
# ==========================================
# Stripe y activado el "Modo Prueba"
STRIPE_PUBLIC_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ==========================================
# 🧾 FACTURACIÓN ESPAÑA (Veri*Factu - Modo Test)
# ==========================================
# ApiKey de Verifacti
VERIFACTU_API_KEY="tu_clave_de_test_aqui"

# ==========================================
# 📧 CORREOS ELECTRÓNICOS (Resend o Nodemailer)
# ==========================================
#  API de prueba de Resend
RESEND_API_KEY="re_..."

# ==========================================
# 🗺️ GOOGLE MAPS & RESEÑAS
# ==========================================
#  clave de Google Cloud Console con la API de "Places" habilitada
GOOGLE_MAPS_API_KEY="AIza..."