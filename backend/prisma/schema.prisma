// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// Role Enum
// ==========================================
enum Role {
  ADMIN
  CUSTOMER
}

// ==========================================
// OrderStatus Enum
// ==========================================
enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// ==========================================
// User Model
// ==========================================
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(CUSTOMER)
  nifCif       String
  fullName     String
  phone        String?
  address      Json     // Embedded: { street, postalCode, city, province, country }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  addresses Address[]
  orders    Order[]

  @@index([email])
  @@index([role])
  @@index([createdAt])
  @@map("users")
}

// ==========================================
// Category Model
// ==========================================
model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[]

  @@index([slug])
  @@index([createdAt])
  @@map("categories")
}

// ==========================================
// Product Model
// ==========================================
model Product {
  id            String        @id @default(uuid())
  name          String
  slug          String        @unique
  description   String?
  price         Int           // Price in cents (avoid float)
  stockQuantity Int           @default(0)
  isActive      Boolean       @default(true)
  taxRate       Decimal       @default(21.00) @db.Decimal(5, 2)
  categoryId    String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  category   Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  images     ProductImage[]

  @@index([categoryId])
  @@index([isActive])
  @@index([price])
  @@index([createdAt])
  @@index([slug])
  @@map("products")
}

// ==========================================
// ProductImage Model
// ==========================================
model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  publicId  String   // Cloudinary public ID
  order     Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// ==========================================
// Address Model
// ==========================================
model Address {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  street      String
  postalCode  String
  city        String
  province    String
  country     String   @default("España")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  shippingOrders Order[] @relation("ShippingAddress")
  billingOrders  Order[] @relation("BillingAddress")

  @@index([userId])
  @@map("addresses")
}

// ==========================================
// Order Model
// ==========================================
model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])

  // Guest fields
  guestEmail      String?
  guestFullName   String?
  guestPhone      String?
  guestNifCif     String?

  status          OrderStatus @default(PENDING)
  subtotal        Int
  shippingCost    Int
  taxAmount       Int
  totalAmount     Int

  shippingAddressId String
  shippingAddress Address @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddressId  String?
  billingAddress  Address? @relation("BillingAddress", fields: [billingAddressId], references: [id])

  stripePaymentIntentId String?
  paidAt          DateTime?
  trackingNumber  String?
  shippedAt       DateTime?
  deliveredAt     DateTime?

  // Immutability: No Verifactu fields here anymore - they are in Invoice
  // Cancellation tracking
  cancelledAt     DateTime?
  cancellationReason String?

  items           OrderItem[]
  invoice         Invoice?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([orderNumber])
  @@map("orders")
}

// ==========================================
// OrderItem Model
// ==========================================
model OrderItem {
  id          String @id @default(uuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  productName String
  productPrice Int
  taxRate     Decimal @default(21.00) @db.Decimal(5, 2)
  quantity    Int

  @@index([orderId])
  @@map("order_items")
}

// ==========================================
// StoreSettings Model
// ==========================================
model StoreSettings {
  id                    String   @id @default(cuid())
  shippingType          String   // 'FREE', 'FIXED', 'THRESHOLD'
  shippingPrice         Int?
  freeShippingThreshold Int?
  updatedAt             DateTime @updatedAt
  updatedBy             String?
}

// ==========================================
// VerifactuInvoice Model
// ==========================================
model VerifactuInvoice {
  id              String    @id @default(uuid())
  orderId         String    @unique
  serie           String
  numero          String
  fechaExpedicion String
  tipoFactura     String
  descripcion     String
  nif             String?
  nombre          String
  lineas          Json      // Array of invoice lines
  importeTotal    String
  
  // Response fields
  uuid            String?
  qrCode          String?   @db.Text
  urlVerificacion String?
  estado          String?
  codigoError     String?
  mensajeError    String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([orderId])
  @@index([uuid])
  @@index([estado])
  @@map("verifactu_invoices")
}

// ==========================================
// Invoice Model
// ==========================================
model Invoice {
  id              String    @id @default(uuid())
  orderId         String    @unique
  order           Order     @relation(fields: [orderId], references: [id])

  invoiceNumber   String    @unique

  // Customer snapshot at purchase time
  customerSnapshot Json     // { name, email, nifCif, address }

  // Items snapshot at purchase time
  itemsSnapshot   Json      // Array of { productId, productName, productPrice, quantity, taxRate }

  // Financials
  subtotal        Int       // cents
  taxAmount       Int       // cents
  total           Int       // cents
  taxRate         Decimal   @db.Decimal(5, 2)

  // Verifactu data
  verifactuUuid   String?
  verifactuQrCode String?   @db.Text
  verifactuUrl    String?
  verifactuStatus String?
  verifactuRegisteredAt DateTime?

  createdAt       DateTime  @default(now())

  @@index([orderId])
  @@index([invoiceNumber])
  @@index([verifactuUuid])
  @@map("invoices")
}
