# ==========================================
# ⚙️ CONFIGURACIÓN DEL SERVIDOR
# ==========================================
# Entorno de ejecución: development, production, test
NODE_ENV=development

# Puerto del servidor
PORT=3000

# URL del frontend (para CORS y cookies)
FRONTEND_URL=http://localhost:5173

# ==========================================
# 🗄️ BASE DE DATOS (PostgreSQL/Supabase)
# ==========================================
# URL de conexión a la base de datos
# Para Supabase: usa el Connection Pooler (puerto 6543)
# Formato: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://user:password@host:5432/database

# ==========================================
# 🛡️ AUTENTICACIÓN Y SEGURIDAD
# ==========================================
# Clave secreta para firmar tokens JWT (mínimo 32 caracteres, usar un generador aleatorio)
JWT_SECRET=your_jwt_secret_minimum_32_characters_here
JWT_EXPIRES_IN=7d

# Credenciales OAuth de Google (desde Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ==========================================
# 💳 PAGOS (Stripe)
# ==========================================
# Clave secreta de Stripe (sk_test_... para pruebas, sk_live_... para producción)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Clave pública de Stripe (pk_test_... para pruebas, pk_live_... para producción)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Secreto del webhook para verificar firmas de eventos de Stripe
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ==========================================
# 🧾 FACTURACIÓN ESPAÑA (Veri*Factu)
# ==========================================
# URL base del API de Verifactu
VERIFACTU_API_URL=https://api.verifactu.com

# Clave del API de Verifactu (proporcionada por Verifactu)
VERIFACTU_API_KEY=vf_test_your_verifactu_api_key

# ==========================================
# 📧 CORREOS ELECTRÓNICOS (Resend)
# ==========================================
# Clave del API de Resend (desde resend.com)
RESEND_API_KEY=re_your_resend_api_key

# Dirección de correo para enviar emails transaccionales
EMAIL_FROM=noreply@yourdomain.com

# Dirección de correo del administrador
ADMIN_EMAIL=admin@yourdomain.com

# ==========================================
# 🗺️ GOOGLE MAPS
# ==========================================
# Clave del API de Google Maps (desde Google Cloud Console)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ==========================================
# ☁️ CLOUDINARY (Gestión de imágenes)
# ==========================================
# Nombre del cloud en Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name

# Clave del API de Cloudinary
CLOUDINARY_API_KEY=your_cloudinary_api_key

# Secreto del API de Cloudinary
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ==========================================
# 📊 REPORTES
# ==========================================
# Ruta donde se guardarán los reportes generados
REPORTS_FOLDER=./reports